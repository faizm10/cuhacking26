# Server
PORT=8080
HOST=0.0.0.0

# Gemini — set USE_MOCK_GEMINI=true to develop without an API key
USE_MOCK_GEMINI=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud (both optional — persistence is skipped when unset)
GOOGLE_CLOUD_PROJECT=
GCS_BUCKET=

# CORS — comma-separated origins, or * for any
CORS_ORIGIN=http://localhost:3000
